</section>

<section class="features">
  <div class="container">
    <div class="features-header">
      <h2>What We Do</h2>
      <p>Comprehensive technology solutions designed for Singapore's SME landscape</p>
    </div>
    
    <div class="features-grid">
      {% for service in services %}
      {% if service.link %}
      <a href="{{ service.link }}" class="feature-card">
        <div class="feature-icon">{{ service.icon }}</div>
        <h3>{{ service.title }}</h3>
        <p>{{ service.description }}</p>
        {% if service.featured %}
        <span class="featured-badge">Featured Product</span>
        {% endif %}
      </a>
      {% else %}
      <div class="feature-card">
        <div class="feature-icon">{{ service.icon }}</div>
        <h3>{{ service.title }}</h3>
        <p>{{ service.description }}</p>
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta">
  <div class="container">
    <div class="cta-box">
