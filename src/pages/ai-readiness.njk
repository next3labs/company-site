<script>
document.getElementById('ai-assessment-form').addEventListener('submit', function(e) {
  e.preventDefault();
  
  let score = 0;
  
  // Sum radio buttons (questions 1-3, 5-10)
  for (let i = 1; i <= 10; i++) {
    if (i === 4) continue; // Skip checkbox question for now
    const selected = document.querySelector('input[name="q' + i + '"]:checked');
    if (selected) {
      score += parseInt(selected.value);
    }
  }
  
  // Question 4: checkboxes (add all checked values)
  const q4Checkboxes = document.querySelectorAll('input[name="q4"]:checked');
  q4Checkboxes.forEach(cb => {
    score += parseInt(cb.value);
  });
  
  // Determine tier
  let tier, emoji, description, actions;
  
  if (score >= 24) {
    tier = 'AI-READY';
    emoji = '🚀';
    description = '<strong>You have the foundation, mindset, and urgency to adopt AI now.</strong><br><br>Your data infrastructure is solid, your technical environment can support AI workloads, and you recognize AI as a strategic priority. The government\'s $50K tax deduction was practically designed for businesses like yours.';
    actions = '<h4>Your Next Steps:</h4><ul><li>Claim your $50K tax deduction with IRAS</li><li>Apply for Champions of AI programme</li><li>Identify 3 high-ROI AI use cases</li><li>Start team training via MySkillsFuture</li></ul>';
  } else if (score >= 16) {
    tier = 'AI-CURIOUS';
    emoji = '📈';
    description = '<strong>You see the AI opportunity and have some foundation, but need clarity on where to start.</strong><br><br>You\'re interested in AI but not quite sure what steps to take first. Budget 2026 was designed exactly for businesses at your stage.';
    actions = '<h4>Your Next Steps:</h4><ul><li>Start with free AI training on MySkillsFuture</li><li>Pick ONE pilot project to prove ROI</li><li>Get expert consultation</li><li>Document everything for business case</li></ul>';
  } else if (score >= 8) {
    tier = 'AI-EXPLORER';
    emoji = '🔍';
    description = '<strong>You\'re in the early stages of understanding AI\'s potential.</strong><br><br>AI sounds interesting but you\'re not sure how it applies to your business. That\'s OK—the government is investing heavily to help businesses like yours.';
    actions = '<h4>Your Next Steps:</h4><ul><li>Learn the basics with free government AI courses</li><li>Organize your business data</li><li>Follow National AI Council updates</li><li>Get an IT infrastructure assessment</li></ul>';
  } else {
    tier = 'AI-BEGINNER';
    emoji = '🌱';
    description = '<strong>You\'re just starting to think about AI and digital transformation.</strong><br><br>Every business starts somewhere. The government\'s initiatives are designed to help businesses at every stage.';
    actions = '<h4>Your Next Steps:</h4><ul><li>Start with free AI basics courses</li><li>Focus on organizing your data foundation</li><li>Watch and learn from industry leaders</li><li>Attend free AI seminars and events</li></ul>';
  }
  
  document.getElementById('score-display').innerHTML = 
    '<div style="font-size: 3rem; margin-bottom: 0.5rem;">' + emoji + '</div>' +
    '<div style="font-size: 1.5rem; font-weight: bold; color: #00d4aa;">' + tier + '</div>' +
    '<div style="font-size: 1.2rem; color: #666;">Score: ' + score + '/30</div>';
  
  document.getElementById('recommendations').innerHTML = 
    '<p style="margin-bottom: 1rem;">' + description + '</p>' + actions;
  
  document.getElementById('results').style.display = 'block';
  document.getElementById('results').scrollIntoView({ behavior: 'smooth' });
});
</script>
